NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 未設定の場合は登録不要の無料ベクタータイル(OpenFreeMap)にフォールバックする
# 取得後にここへ設定するだけでMapTilerへ切り替わる
# (ブラウザで直接MapTilerを呼ぶため、Next.jsの制約上 NEXT_PUBLIC_ が必須)
NEXT_PUBLIC_MAPTILER_API_KEY=

# 地図上の場所検索の精度向上用（任意）。Yahoo!デベロッパーネットワークで取得するアプリケーションID。
# サーバー側のAPI Route(src/app/api/geocode/route.ts)でのみ使うため、NEXT_PUBLIC_は付けない
# (ブラウザに公開されない)。未設定の場合はMapTiler→Nominatimの順にフォールバックする
YAHOO_CLIENT_ID=
